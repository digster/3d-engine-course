# ---- Build output -----------------------------------------------------------
build/
build-*/
out/
cmake-build-*/
install/

# ---- CMake noise ------------------------------------------------------------
CMakeCache.txt
CMakeFiles/
CMakeUserPresets.json
cmake_install.cmake
compile_commands.json
CTestTestfile.cmake
Testing/
_deps/

# ---- Compiled shader artifacts ----------------------------------------------
# HLSL sources under shaders/ are tracked; everything SDL_shadercross emits is not.
*.spv
*.dxil
*.dxbc
*.msl
shaders/compiled/

# ---- Fetched dependencies ---------------------------------------------------
# SDL3 and friends arrive via FetchContent into the build tree; never commit them.
third_party/*/
!third_party/README.md

# ---- Binaries & libraries ---------------------------------------------------
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.pdb
*.ilk
*.exp

# ---- IDE / editor -----------------------------------------------------------
.vs/
.vscode/*
!.vscode/settings.json.example
.idea/
*.user
*.swp
*~
.cache/

# ---- OS ---------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---- Profiling & debugging captures -----------------------------------------
*.rdc
*.nvvp
*.trace
callgrind.out.*
perf.data*

# ---- Local scratch ----------------------------------------------------------
scratch/
*.log
